import time
import random
import matplotlib.pyplot as plt
def linear_search(arr, key):
    for i in range(len(arr)):
        if arr[i] == key:
            return i
    return -1
def binary_search(arr, key):
    low = 0
    high = len(arr) - 1

    while low <= high:
        mid = (low + high) // 2
        if arr[mid] == key:
            return mid
        elif arr[mid] < key:
            low = mid + 1
        else:
            high = mid - 1
    return -1
input_sizes = [10, 100, 500, 1000]
ls_best = []
ls_avg = []
ls_worst = []

bs_best = []
bs_avg = []
bs_worst = []
for n in input_sizes:
    arr = sorted(random.sample(range(1, n*5), n))

    start = time.time()
    linear_search(arr, arr[0])
    ls_best.append(time.time() - start)
    
    
    start = time.time()
    linear_search(arr, arr[n//2])
    ls_avg.append(time.time() - start)
    
   
    start = time.time()
    linear_search(arr, -1)
    ls_worst.append(time.time() - start)
    
   
    start = time.time()
    binary_search(arr, arr[n//2])
    bs_best.append(time.time() - start)
    
   
    start = time.time()
    binary_search(arr, random.choice(arr))
    bs_avg.append(time.time() - start)
    
  
    start = time.time()
    binary_search(arr, -1)
    bs_worst.append(time.time() - start)
plt.figure(figsize=(10, 6))

plt.plot(input_sizes, ls_best, marker='o', label='Linear Search Best')
plt.plot(input_sizes, ls_avg, marker='o', label='Linear Search Average')
plt.plot(input_sizes, ls_worst, marker='o', label='Linear Search Worst')

plt.plot(input_sizes, bs_best, marker='o', label='Binary Search Best')
plt.plot(input_sizes, bs_avg, marker='o', label='Binary Search Average')
plt.plot(input_sizes, bs_worst, marker='o', label='Binary Search Worst')

plt.xlabel("Input Size (n)")
plt.ylabel("Execution Time (seconds)")
plt.title("Best, Average, Worst Case Comparison")
plt.legend()
plt.grid(True)
